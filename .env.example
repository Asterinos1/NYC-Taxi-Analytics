# NYC Taxi Analytics - Environment Configuration

# Airflow UID/GID (for Linux hosts, default is 50000)
AIRFLOW_UID=50000
AIRFLOW_GID=0

# Image versions
AIRFLOW_IMAGE_NAME=apache/airflow:3.2.2
SPARK_IMAGE_NAME=apache/spark:3.5.6
POSTGRES_IMAGE_NAME=postgres:16

# Postgres Configuration
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow_password
POSTGRES_DB=airflow

# Spark Configuration
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=4G

# Pipeline parameters
TARGET_SAMPLE_SIZE=100000
CMS_EPSILON=0.0001
CMS_CONFIDENCE=0.95
CMS_SEED=1
